# SocialSync OAuth Credentials
# Copy this file to .env and fill in your actual credentials

# Google OAuth (Required for Google Drive and YouTube)
# Get these from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret

# Instagram / Meta (Required for Instagram posting)
# Get these from: https://developers.facebook.com/apps/
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret

# Notes:
# 1. Create a Google Cloud project and enable Drive API + YouTube Data API v3
# 2. Create OAuth 2.0 credentials with redirect URI: http://localhost:8585/callback
# 3. For Instagram, create a Facebook App and add Instagram Graph API product
# 4. See SETUP_CREDENTIALS.md for detailed instructions
